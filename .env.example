# =============================================================================
# ATLAS v4.0 Configuration File
# =============================================================================
# Copy this file to .env and fill in your API credentials
# =============================================================================

# -----------------------------------------------------------------------------
# Chainlink Data Streams (Primary Market Data)
# -----------------------------------------------------------------------------
# Get your API credentials at: https://chain.link/data-streams
CHAINLINK_ACCESS_KEY=
CHAINLINK_SECRET=
CHAINLINK_STREAM_ID=BTC-USD

# -----------------------------------------------------------------------------
# LLM Providers (At least one required for agent analysis)
# -----------------------------------------------------------------------------

# NVIDIA NIM API (Free tier available)
NVIDIA_API_KEY=
NIM_API_KEY=

# OpenAI API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# -----------------------------------------------------------------------------
# Trading Configuration
# -----------------------------------------------------------------------------

PAPER_TRADING=true
INITIAL_CAPITAL=10000
MAX_POSITION_PERCENT=10
KELLY_FRACTION=0.5
MIN_CONFIDENCE=0.5
MIN_EDGE=0.02
MAX_DRAWDOWN_PERCENT=20

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

ENABLE_BACKTEST=false
ENABLE_AGENT_IMPROVEMENT=true
ENABLE_REGIME_SELECTION=true
ENABLE_MTF_ANALYSIS=true
ENABLE_DERIVATIVES=true
ENABLE_ONCHAIN=true
ENABLE_SENTIMENT=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

LOG_LEVEL=INFO
